# ============================================================
# Odysseus TG Voice Bot — config template (copy to .env, fill in)
# ============================================================

# --- Telegram (userbot) ---  https://my.telegram.org
TG_API_ID=
TG_API_HASH=
TG_SESSION_NAME=odysseus_userbot

# Optional: non-interactive first login (./tools/tg_setup.py login)
# TG_PHONE=+79XXXXXXXXX
# TG_CODE=12345
# TG_PASSWORD=

# Owner Telegram id/username (only this user can control the bot)
TG_OWNER_ID=
TG_OWNER_USERNAME=
TG_TEST_GROUP_ID=

# --- SOCKS5 proxy for Telegram and external APIs (optional) ---
PROXY_URL=
PROXY_URL_HTTP=
TG_USE_PROXY=1
TG_PROXY_KIND=socks5

# --- Deepgram STT ---  https://console.deepgram.com
DEEPGRAM_API_KEY=
DEEPGRAM_API_KEYS=
DEEPGRAM_STT_MODEL=nova-3
DEEPGRAM_STT_LANG=ru

# --- Cartesia TTS ---  https://play.cartesia.ai
CARTESIA_API_KEY=
CARTESIA_API_KEYS=
CARTESIA_VOICE_ID=7a62541e-5492-410e-95ff-3abd096fce87
CARTESIA_MODEL_ID=sonic-3.5

# --- LLM Brain (OpenAI-compatible endpoint) ---
BRAIN_BACKEND=odysseus
BRAIN_URL=http://odysseus_shim:9200/v1
BRAIN_API_KEY=local-no-auth
BRAIN_MODEL=deepseek-v4-flash

# --- Audio ---
CALL_SAMPLE_RATE=48000
CALL_CHANNELS=2
FRAME_MS=20

# --- Persona ---
PERSONA_FILE=/app/prompts/persona_odysseus.txt
